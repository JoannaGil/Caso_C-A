<!-- Etapa 3 (continuación): Limpieza y preparación -->

```{r limpieza-basica, echo=FALSE, results='hide'}
# 1) Eliminar duplicados
vivienda_clean <- viviendaSNA[!duplicated(viviendaSNA), ]

# 2) Separar variables numéricas (PCA usa solo numéricas) y excluir id
vars_num <- names(vivienda_clean)[sapply(vivienda_clean, is.numeric)]
vars_num <- setdiff(vars_num, "id")
vivienda_num <- vivienda_clean[, vars_num, drop = FALSE]

# Resumen rápido después de limpieza
str(vivienda_clean)
```

<!-- Etapa 4: Detección de datos atípicos (outliers) -->
<!-- Usamos el criterio de Tukey (1.5*IQR) para identificar valores extremos en variables numéricas. -->

```{r outliers-prep, echo=FALSE, results='hide'}
# Seleccionar solo variables numéricas y excluir id
vars_num <- names(viviendaSNA)[sapply(viviendaSNA, is.numeric)]
vars_num <- setdiff(vars_num, "id")
vivienda_num <- viviendaSNA[, vars_num, drop = FALSE]

# Etiquetas en español para variables
etiquetas <- c(
  estrato = "Estrato",
  preciom = "Precio",
  areaconst = "Area construida",
  parqueaderos = "Parqueaderos",
  banios = "Baños",
  habitaciones = "Habitaciones",
  longitud = "Longitud",
  latitud = "Latitud"
)
label_var <- function(x) ifelse(x %in% names(etiquetas), etiquetas[x], x)
```

```{r outliers-iqr, echo=FALSE, results='hide'}
# Calcular límites IQR y marcar atípicos
iqr_bounds <- lapply(vivienda_num, function(x) {
  q1 <- quantile(x, 0.25, na.rm = TRUE)
  q3 <- quantile(x, 0.75, na.rm = TRUE)
  iqr <- q3 - q1
  c(lower = q1 - 1.5 * iqr, upper = q3 + 1.5 * iqr)
})

outlier_flags <- mapply(function(x, b) x < b["lower"] | x > b["upper"], 
                        vivienda_num, iqr_bounds, SIMPLIFY = FALSE)

outlier_counts <- sapply(outlier_flags, sum, na.rm = TRUE)
outlier_counts
```

```{r outliers-rows, echo=FALSE, results='hide'}
# Filas que contienen al menos un atípico
rows_with_outliers <- which(Reduce(`|`, outlier_flags))
length(rows_with_outliers)
```

```{r outliers-preview, echo=FALSE, results='hide'}
